[
  { "text": "从前书信很慢，车马很远，一生只够爱一个人。", "from": "木心", "image": "https://images.unsplash.com/photo-1507400492013-162706c8c05e?w=1920&q=80" },
  { "text": "我爱你，不光因为你的样子，还因为，和你在一起时，我的样子。", "from": "罗伊·克里夫特", "image": "https://images.unsplash.com/photo-1518459031867-a89b944bffe4?w=1920&q=80" },
  { "text": "我把我整个灵魂都给你，连同它的怪癖，耍小脾气，忽明忽暗，一千八百种坏毛病。它真讨厌，只有一点好，爱你。", "from": "王小波", "image": "https://images.unsplash.com/photo-1470252649378-9c29740c9fa8?w=1920&q=80" },
  { "text": "春水初生，春林初盛，春风十里，不如你。", "from": "冯唐", "image": "https://images.unsplash.com/photo-1506744038136-46273834b3fb?w=1920&q=80" },
  { "text": "草在结它的种子，风在摇它的叶子。我们站着，不说话，就十分美好。", "from": "顾城", "image": "https://images.unsplash.com/photo-1507400492013-162706c8c05e?w=1920&q=80" },
  { "text": "我行过许多地方的桥，看过许多次数的云，喝过许多种类的酒，却只爱过一个正当最好年龄的人。", "from": "沈从文", "image": "https://images.unsplash.com/photo-1518459031867-a89b944bffe4?w=1920&q=80" }
]
